# OhMyAgent Agent Server Environment Variables

# Qiniu Baidu Search API Key
# Get your API key from: https://api.qnaigc.com/v1
# Required for websearch tool (Baidu provider)
QINIU_API_KEY=your_qiniu_api_key_here

# Optional: DeepSeek API Key (already hardcoded in pi-agent.ts for MVP)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
