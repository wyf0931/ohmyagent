    "typebox": "^1.1.39"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0"
  }
